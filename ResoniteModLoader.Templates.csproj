<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<PackageType>Template</PackageType>
		<PackageVersion>1.0.0</PackageVersion>
		<Title>ResoniteModLoader Templates</Title>
		<Description>Templates for creating mods for ResoniteModLoader.</Description>
		<Authors>resonite-modding-group</Authors>
		<Copyright>Copyright © 2026</Copyright>
		<PackageTags>dotnet-new;templates;mod;mods;modding;harmony;resonite;game;resonitemodloader;frooxengine</PackageTags>
		<TargetFramework>net10.0</TargetFramework>

		<IncludeContentInPack>true</IncludeContentInPack>
		<IncludeBuildOutput>false</IncludeBuildOutput>
		<ContentTargetFolders>content</ContentTargetFolders>
	</PropertyGroup>

	<ItemGroup>
		<Content Include="templates\**\**" Exclude="templates\**\bin\**;templates\**\obj\**"/>
		<Compile Remove="**\**"/>
	</ItemGroup>

</Project>

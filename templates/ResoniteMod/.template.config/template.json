{
	"$schema": "http://json.schemastore.org/template",
	"author": "resonite-modding-group",
	"classifications": [
		"Modding",
		"Resonite"
	],
	"name": "Resonite Mod",
	"description": "A basic mod for ResoniteModLoader.",
	"identity": "ResoniteModLoader.Templates.ResoniteMod",
	"shortName": "rmlmod",
	"tags": {
		"language": "C#",
		"type": "project"
	},
	"sourceName": "_ProjectName_",
	"preferNameDirectory": true,
	"symbols": {
		"ModId": {
			"type": "parameter",
			"datatype": "string",
			"displayName": "Mod ID",
			"description": "Unique mod ID in reverse domain name notation (e.g. com.example.ResoniteMod).",
			"replaces": "_ModId_",
			"isRequired": true
		},
		"Author": {
			"type": "parameter",
			"datatype": "string",
			"displayName": "Author",
			"description": "Name of the mod author.",
			"replaces": "_ModAuthorName_",
			"isRequired": true
		},
		"Description": {
			"type": "parameter",
			"datatype": "string",
			"displayName": "Description",
			"description": "Description of the mod.",
			"replaces": "_ModDescription_",
			"defaultValue": ""
		},
		"Link": {
			"type": "parameter",
			"datatype": "string",
			"displayName": "Mod Link",
			"description": "Link to the mod download/source.",
			"replaces": "_ModLink_",
			"defaultValue": ""
		},
		"HostIdentifier": {
			"type": "bind",
			"binding": "host:HostIdentifier"
		}
	},
	"primaryOutputs": [
		{
			"path": "_ProjectName_.csproj"
		},
		{
			"condition": "(HostIdentifier != \"dotnetcli\" && HostIdentifier != \"dotnetcli-preview\")",
			"path": "_ProjectName_.cs"
		}
	],
	"postActions": [
		{
			"id": "restore",
			"description": "Restore NuGet packages required by this project.",
			"manualInstructions": [
				{
					"text": "Run 'dotnet restore'"
				}
			],
			"actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
			"continueOnError": true
		},
		{
			"id": "open-file",
			"condition": "(HostIdentifier != \"dotnetcli\" && HostIdentifier != \"dotnetcli-preview\")",
			"description": "Opens _ProjectName_.cs in the editor",
			"manualInstructions": [],
			"actionId": "84C0DA21-51C8-4541-9940-6CA19AF04EE6",
			"args": {
				"files": "1"
			},
			"continueOnError": true
		}
	]
}
